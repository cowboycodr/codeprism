{
  "name": "codeprism",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "CODEPRISM_HTTP_PORT=${CODEPRISM_HTTP_PORT:-5182} npm run dev --workspace @codeprism/api",
    "dev:web": "npm run dev --workspace @codeprism/web",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview -w @codeprism/web",
    "check": "npm run check --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.48.6",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.0",
    "lucide-svelte": "^0.468.0",
    "npm-run-all": "^4.1.5",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.14",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.7",
    "postcss": "^8.5.6",
    "svelte": "^5.40.0",
    "svelte-check": "^4.3.3",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
